# Copie este arquivo para .env.local e preencha com as chaves reais.
# .env.local está no .gitignore — nunca commite credenciais.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Apenas para scripts locais (seed/migrações). NUNCA exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_DB_PASSWORD=your-db-password-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Flag pra alternar entre mock data e Supabase real
VITE_DATA_SOURCE=mock
